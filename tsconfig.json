{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "noImplicitAny": false,
    "strictPropertyInitialization": false,
    "sourceMap": true,
    "noEmit": false,
  },
  "include": [
    "src/**/*",
    "src/knexfile.mjs"
  ],
  "exclude": ["node_modules", "dist"]
}