{
  "name": "usermanagement",
  "version": "1.0.0",
  "type": "module",
  "description": "User management and post backend system",
  "main": "dist/index.ts",
  "scripts": {
    "dev": "npx tsx src/index.ts",
    "start:dev": "nodemon --exec tsx src/index.ts",
    "build": "tsc",
    "migrate": "knex migrate:latest --knexfile src/knexfile.mjs",
    "rollback": "knex migrate:rollback --knexfile src/knexfile.mjs",
    "seed": "knex seed:run --knexfile src/knexfile.mjs",
    "lint": "eslint src --ext .ts"
  },
  "author": "Ijiwole Adedamola",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "joi": "^17.13.3",
    "jsonwebtoken": "^9.0.2",
    "knex": "^3.1.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.13.9",
    "@types/supertest": "^6.0.2",
    "eslint": "^9.21.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.9",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
